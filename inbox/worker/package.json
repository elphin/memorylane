{
  "name": "memorylane-inbox-worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "MemoryLane Onderweg — Cloudflare Worker (API + brievenbus). Losstaand van de root-app.",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "check": "wrangler deploy --dry-run --outdir dist",
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "migrate:local": "wrangler d1 migrations apply memorylane-inbox --local",
    "migrate:remote": "wrangler d1 migrations apply memorylane-inbox --remote"
  },
  "dependencies": {
    "hono": "^4.6.14"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260708.1",
    "typescript": "^5.7.2",
    "wrangler": "^4.20.0"
  }
}
